[
  // Native Tabs on Mac (skip for Linux)
  {
    "key": "shift+cmd+]",
    "command": "workbench.action.showNextWindowTab"
  },
  {
    "key": "shift+cmd+[",
    "command": "workbench.action.showPreviousWindowTab"
  },
  {
    "key": "shift+cmd+t",
    "command": "workbench.action.newWindowTab"
  },
  // Split shortcuts
  {
    "key": "ctrl+-",
    "command": "-workbench.action.navigateBack",
    "when": "canNavigateBack"
  },
  {
    "key": "ctrl+o",
    "command": "-lineBreakInsert",
    "when": "textInputFocus && !editorReadonly"
  },
  {
    "key": "ctrl+w",
    "command": "-workbench.action.switchWindow"
  },
  {
    "key": "ctrl+w l",
    "command": "workbench.action.focusRightGroup"
  },
  {
    "key": "cmd+r cmd+right",
    "command": "-workbench.action.focusRightGroup"
  },
  {
    "key": "ctrl+w h",
    "command": "workbench.action.focusLeftGroup"
  },
  {
    "key": "cmd+r cmd+left",
    "command": "-workbench.action.focusLeftGroup"
  },
  // Remove the shift enter to run python
  {
    "key": "shift+enter",
    "command": "-python.execInREPL",
    "when": "config.python.REPL.sendToNativeREPL && editorTextFocus && !accessibilityModeEnabled && !jupyter.ownsSelection && !notebookEditorFocused && editorLangId == 'python' && activeEditor != 'workbench.editor.interactive'"
  },
  {
    "key": "shift+enter",
    "command": "-python.execSelectionInTerminal",
    "when": "editorTextFocus && !findInputFocussed && !jupyter.ownsSelection && !notebookEditorFocused && !replaceInputFocussed && editorLangId == 'python' && activeEditor != 'workbench.editor.interactive'"
  },
  {
    "key": "cmd+i",
    "command": "composerMode.agent"
  },
  // Remove current stuff cmd shift h & l
  {
    "key": "shift+cmd+h",
    "command": "-workbench.action.replaceInFiles"
  },
  {
    "key": "shift+cmd+l",
    "command": "-selectAllSearchEditorMatches",
    "when": "inSearchEditor"
  },
  {
    "key": "shift+cmd+l",
    "command": "-editor.action.selectHighlights",
    "when": "editorFocus"
  },
  {
    "key": "shift+cmd+l",
    "command": "-addCursorsAtSearchResults",
    "when": "fileMatchOrMatchFocus && searchViewletVisible"
  },
  {
    "key": "shift+cmd+l",
    "command": "-windsurf.prioritized.chat.openNewConversation",
    "when": "!terminalFocus"
  },
  {
    "key": "shift+cmd+l",
    "command": "-windsurf.prioritized.chat.openNewConversationFromTerminal",
    "when": "terminalFocus"
  },
  {
    "key": "shift+cmd+l",
    "command": "-notebook.selectAllFindMatches",
    "when": "config.notebook.multiCursor.enabled && notebookFindWidgetFocused || config.notebook.multiCursor.enabled && notebookCellEditorFocused && activeEditor == 'workbench.editor.notebook'"
  },
  {
    "key": "shift+cmd+9",
    "command": "workbench.action.mergeAllWindowTabs"
  },
  {
    "key": "shift+cmd+]",
    "command": "-workbench.action.nextEditor"
  },
  {
    "key": "shift+cmd+[",
    "command": "-workbench.action.previousEditor"
  },
  // Show documentations
  {
    "key": "shift+k",
    "command": "editor.action.showHover",
    "when": "editorTextFocus && vim.mode == 'Normal' && vim.active"
  },
  // Code navigation
  {
    "key": "alt+f12",
    "command": "-editor.action.peekDefinition",
    "when": "editorHasDefinitionProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
  },
  {
    "key": "alt+f12",
    "command": "editor.action.revealDeclaration"
  },
  // Tab navigation
  {
    "key": "alt+l",
    "command": "workbench.action.nextEditor",
    "when": "(vim.mode == 'Normal' && vim.active && editorFocus) || (terminalFocus)"
  },
  {
    "key": "alt+h",
    "command": "workbench.action.previousEditor",
    "when": "(vim.mode == 'Normal' && vim.active && editorFocus) || (terminalFocus)"
  },
  // Vim keybindings (migrated from settings.json)
  {
    "key": "space b d",
    "command": "workbench.action.closeActiveEditor",
    "when": "vim.mode == 'Normal' && vim.active && editorFocus"
  },
  {
    "key": "space b o",
    "command": "workbench.action.closeOtherEditors",
    "when": "vim.mode == 'Normal' && vim.active && editorFocus"
  },
  {
    "key": "space o t",
    "command": "workbench.action.terminal.toggleTerminal",
    "when": "vim.mode == 'Normal' && vim.active && editorFocus"
  },
  {
    "key": "space c f",
    "command": "editor.action.formatDocument",
    "when": "vim.mode == 'Normal' && vim.active && editorFocus"
  },
  {
    "key": "space s g",
    "command": "workbench.action.findInFiles",
    "when": "vim.mode == 'Normal' && vim.active && editorFocus"
  },
  {
    "key": "g r",
    "command": "editor.action.goToReferences",
    "when": "vim.mode == 'Normal' && vim.active && editorFocus"
  },
  {
    "key": "g shift+i",
    "command": "editor.action.goToImplementation",
    "when": "vim.mode == 'Normal' && vim.active && editorFocus"
  },
  {
    "key": "g d",
    "command": "editor.action.revealDeclaration",
    "when": "vim.mode == 'Normal' && vim.active && editorFocus"
  },
  {
    "key": "g g",
    "command": "cursorTop",
    "when": "vim.mode == 'Normal' && vim.active && editorFocus"
  },
  {
    "key": "space e",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "vim.mode == 'Normal' && vim.active && editorFocus"
  },
  {
    "key": "space a r",
    "command": "roo-cline.focusInput",
    "when": "vim.mode == 'Normal' && vim.active && editorFocus"
  },
  {
    "key": "space a c",
    "command": "claude-vscode.focus",
    "when": "vim.mode == 'Normal' && vim.active && editorFocus"
  },
  {
    "key": "ctrl+shift+t",
    "command": "workbench.action.createTerminalEditor"
  }
]